<table class="w-full" >
    <tr>
        <th>Type</th>
        <th>Dependencies</th>
        <th>Out of date</th>
        <th>Imported</th>
    </tr>

    <% @lockfiles.each do |lockfile| %>
        <tr>
            <td><%= link_to lockfile.type, lockfile_path( lockfile ), class: "hover:underline" %></td>
            <td><%= lockfile.dependencies.count %></td>
            <td><%= lockfile.out_of_date.count %></td>
            <td><%= lockfile.created_at.strftime( "%Y-%m-%d" ) %></td>
        </tr>
    <% end %>
</table>
    
